# MongoDB Atlas connection string (Atlas UI: Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/collabspace?retryWrites=true&w=majority

# Port the API + websockets listen on
PORT=4000

# Origin of the React app, for CORS (Vite dev server default)
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign JWTs (generate one: openssl rand -hex 32)
JWT_SECRET=change-me
